<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverage scoping for RapidRepo. Replaces the per-project inline
  DataCollectionRunSettings filters that lived in the old dotnet-build.yml.
  Passed to dotnet test by the shared ci-toolkit workflow (runsettings input)
  so coverage measures only the product assemblies.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[RapidRepo]*,[RapidRepo.Extensions.DependencyInjection]*,[RapidRepo.SourceGenerators]*</Include>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
